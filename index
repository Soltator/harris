<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Harris KX • 50 тестів</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            background: #f5efe6;  /* слонова кістка фон */
            padding: 20px;
            line-height: 1.5;
        }
        
        .container {
            max-width: 900px;
            margin: 0 auto;
            background: #fff9ef;  /* світлий кремовий */
            border-radius: 30px;
            padding: 30px;
            box-shadow: 0 10px 30px rgba(139, 119, 101, 0.15);
            border: 1px solid #e8dccc;
        }
        
        h1 {
            color: #5e4b3c;
            font-size: 2em;
            margin-bottom: 10px;
            padding-bottom: 15px;
            border-bottom: 2px solid #e8dccc;
            font-weight: 500;
        }
        
        .subtitle {
            color: #8b7a6b;
            margin-bottom: 25px;
            font-style: italic;
        }
        
        .panel {
            background: #f5ede1;
            border-radius: 50px;
            padding: 15px 25px;
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid #e0d2c0;
        }
        
        .score {
            background: #b7a187;
            color: white;
            padding: 10px 30px;
            border-radius: 40px;
            font-weight: bold;
            font-size: 1.3rem;
        }
        
        .btn {
            background: white;
            border: 2px solid #b7a187;
            color: #5e4b3c;
            padding: 10px 25px;
            margin-left: 15px;
            border-radius: 40px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.2s;
            font-size: 1rem;
        }
        
        .btn:hover {
            background: #b7a187;
            color: white;
        }
        
        .questions {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }
        
        .card {
            background: #fffcf5;
            border: 1px solid #e8dccc;
            border-radius: 25px;
            padding: 20px;
            transition: 0.1s;
        }
        
        .card.correct {
            background: #e8f0e3;
            border-left: 8px solid #7a9e7a;
        }
        
        .card.incorrect {
            background: #fceaea;
            border-left: 8px solid #d19a9a;
        }
        
        .qtitle {
            font-weight: 600;
            color: #5e4b3c;
            margin-bottom: 15px;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
        }
        
        .qnum {
            background: #e8dccc;
            padding: 5px 15px;
            border-radius: 30px;
            margin-right: 15px;
            font-size: 0.9rem;
            color: #5e4b3c;
        }
        
        .options {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 15px;
        }
        
        .opt {
            display: flex;
            align-items: center;
            padding: 10px 20px;
            background: #f5efe6;
            border-radius: 40px;
            cursor: pointer;
            border: 1px solid #e0d2c0;
        }
        
        .opt:hover {
            background: #e8dccc;
        }
        
        .opt input[type="radio"] {
            margin-right: 15px;
            width: 18px;
            height: 18px;
            accent-color: #b7a187;
        }
        
        .feedback {
            margin-top: 15px;
            padding: 15px;
            background: #f5efe6;
            border-radius: 20px;
            border-left: 5px solid #b7a187;
        }
        
        .correct-msg {
            color: #2d6a2d;
            font-weight: bold;
        }
        
        .wrong-msg {
            color: #b33c3c;
            font-weight: bold;
        }
        
        .explain {
            margin-top: 10px;
            color: #6b5a4b;
        }
        
        hr {
            margin: 30px 0 20px;
            border: none;
            border-top: 2px dashed #e0d2c0;
        }
        
        footer {
            text-align: center;
            color: #b7a187;
            margin-top: 20px;
        }
    </style>
</head>
<body>
<div class="container">
    <h1>🧭 Harris KX • 50 тестів</h1>
    <div class="subtitle">модуляції, режими роботи, модеми, вокодери</div>
    
    <div class="panel">
        <span class="score" id="scoreDisplay">0/50</span>
        <div>
            <button class="btn" id="checkBtn">✅ Перевірити</button>
            <button class="btn" id="resetBtn">🔄 Скинути</button>
        </div>
    </div>
    
    <div class="questions" id="questionsContainer"></div>
    
    <hr>
    <footer>для молодшої сестри • колір слонової кістки</footer>
</div>

<script>
(function() {
    const questions = [
        // 1-5 модуляції
        { q: "Що таке модуляція?", 
          opts: ["Підсилення сигналу", "Зміна несучої за законом сигналу", "Аналого-цифрове перетворення", "Шифрування мови"], 
          correct: 1,
          exp: "Модуляція — зміна параметрів несучої (амплітуди, частоти, фази) відповідно до сигналу." },
        
        { q: "Як називають процес для цифрових сигналів?", 
          opts: ["Модуляція", "Маніпуляція", "Демодуляція", "Кодування"], 
          correct: 1,
          exp: "Для цифрових сигналів використовують термін «маніпуляція» (FSK, ASK, PSK)." },
        
        { q: "Що таке несуча частота?", 
          opts: ["Модульований сигнал", "Сигнал до модуляції", "Бічна смуга", "Інформаційний сигнал"], 
          correct: 1,
          exp: "Несуча — чисте коливання високої частоти, яке модулюють сигналом." },
        
        { q: "Яку модуляцію використовує Harris в КХ?", 
          opts: ["LSB", "AME", "USB", "CW"], 
          correct: 2,
          exp: "USB (Upper Side Band) — стандарт для Harris у КХ діапазоні." },
        
        { q: "Яка модуляція для старих радіостанцій?", 
          opts: ["USB", "LSB", "AME", "FM"], 
          correct: 2,
          exp: "AME (амплітудна модуляція з несучею) сумісна зі старими зразками." },
        
        // 6-10
        { q: "Яку модуляцію люблять радіоаматори в КХ?", 
          opts: ["USB", "LSB", "AME", "CW"], 
          correct: 1,
          exp: "LSB (Lower Side Band) — традиційна аматорська модуляція на КХ." },
        
        { q: "Яка модуляція використовує азбуку Морзе?", 
          opts: ["AME", "FM", "USB", "CW"], 
          correct: 3,
          exp: "CW (Continuous Wave) — телеграфний режим." },
        
        { q: "RF-7800H-MP підтримує FM?", 
          opts: ["Так, в КХ", "Так, в УКХ", "Ні", "Тільки HOP"], 
          correct: 1,
          exp: "FM доступна в УКХ діапазоні." },
        
        { q: "MPR-9600-MP має FM?", 
          opts: ["Так", "Ні", "Тільки в КХ", "Тільки цифрову"], 
          correct: 1,
          exp: "MPR-9600-MP не підтримує FM." },
        
        { q: "Верхня бічна смуга без несучої — це?", 
          opts: ["LSB", "AME", "USB", "DSB"], 
          correct: 2,
          exp: "USB — Upper Side Band, несуча пригнічена." },
        
        // 11-15
        { q: "Нижня бічна смуга без несучої — це?", 
          opts: ["USB", "AME", "LSB", "FM"], 
          correct: 2,
          exp: "LSB — Lower Side Band." },
        
        { q: "ALE розшифровується як?", 
          opts: ["Фіксована частота", "Автоматичне встановлення зв'язку", "ППРЧ", "Адаптивний вибір"], 
          correct: 1,
          exp: "Automatic Link Establishment." },
        
        { q: "Скільки каналів у FIX?", 
          opts: ["63", "200", "19", "50"], 
          correct: 1,
          exp: "FIX — до 200 каналів (0-199)." },
        
        { q: "3G — це?", 
          opts: ["ППРЧ", "Модернізований ALE", "Фіксована частота", "Режим передачі даних"], 
          correct: 1,
          exp: "3G (Third Generation ALE) — швидший, з LVD та GPS." },
        
        { q: "HOP — це?", 
          opts: ["Сканування", "Псевдовипадкова перестройка частоти", "Автоматичний вибір", "Режим малопотужний"], 
          correct: 1,
          exp: "Frequency Hopping — захист від перешкод." },
        
        // 16-20
        { q: "Максимум хопсетів у HOP?", 
          opts: ["63", "200", "19", "32"], 
          correct: 2,
          exp: "HOP підтримує до 19 хопсетів." },
        
        { q: "Синхронізація HOP допускає похибку часу?", 
          opts: ["±30 с", "±1 хв", "±1,5 хв", "±5 хв"], 
          correct: 2,
          exp: "Не більше ±1,5 хвилини." },
        
        { q: "Перевага 3G перед ALE?", 
          opts: ["Вища швидкість, LVD, GPS", "Простіше налаштування", "Менше каналів", "Без синхронізації"], 
          correct: 0,
          exp: "3G швидший, передає голосові повідомлення та GPS." },
        
        { q: "3G+ дозволяє?", 
          opts: ["Тільки голос", "Контроль ALE та 3G одночасно", "Лише дані", "Роботу без антени"], 
          correct: 1,
          exp: "3G+ працює з мережами ALE та 3G." },
        
        { q: "Скільки каналів у 3G?", 
          opts: ["200 (0-199)", "63 (100-162)", "19", "99"], 
          correct: 1,
          exp: "3G — до 63 каналів (100-162)." },
        
        // 21-25 модеми
        { q: "Модем для FIX/ALE?", 
          opts: ["SERIAL", "ARQ", "WBHF", "MIL-110B"], 
          correct: 3,
          exp: "MIL-110B для FIX та ALE." },
        
        { q: "120 кбіт/с в 3G дає модем?", 
          opts: ["SERIAL", "ARQ", "WBHF", "XDL"], 
          correct: 2,
          exp: "WBHF — широкосмуговий HF." },
        
        { q: "2400 біт/с для FIX/ALE/HOP?", 
          opts: ["MIL-110B", "WBFSK", "XDL", "SERIAL/ARQ"], 
          correct: 3,
          exp: "SERIAL та ARQ працюють на 2400 біт/с." },
        
        { q: "Модем тільки для 3G 75-9600?", 
          opts: ["WBHF", "WBFSK", "XDL", "SERIAL"], 
          correct: 2,
          exp: "XDL — тільки 3G, 75-9600 біт/с." },
        
        { q: "Модем для УКХ?", 
          opts: ["WBHF", "WBFSK", "XDL", "ARQ"], 
          correct: 1,
          exp: "WBFSK — широкосмуговий для УКХ." },
        
        // 26-30 вокодери
        { q: "Вокодер — це?", 
          opts: ["Підсилювач", "Перетворювач голосу в цифру", "Шифратор", "Антена"], 
          correct: 1,
          exp: "Voice coder — оцифровує/декодує мову." },
        
        { q: "Аналогова телефонія без вокодера?", 
          opts: ["CVSD", "ME24", "CLR", "DV24"], 
          correct: 2,
          exp: "CLR (clear) — аналог." },
        
        { q: "MELP 2400 біт/с?", 
          opts: ["DV24", "CVSD", "AVS", "ME24"], 
          correct: 3,
          exp: "ME24 — сучасний MELP 2400." },
        
        { q: "Вокодер для УКХ?", 
          opts: ["ME24", "DV6", "CVSD", "AVS"], 
          correct: 2,
          exp: "CVSD (дельта-модуляція) для УКХ." },
        
        { q: "Застарілий 2400 біт/с?", 
          opts: ["ME24", "DV24", "CVSD", "ME12"], 
          correct: 1,
          exp: "DV24 — застарілий цифровий голос 2400." },
        
        // 31-35
        { q: "AVS — це?", 
          opts: ["Цифра низької швидкості", "Аналогове скремблювання", "MELP", "Без вокодера"], 
          correct: 1,
          exp: "AVS — аналогове шифрування (скремблер)." },
        
        { q: "ME6 — яка швидкість?", 
          opts: ["600 біт/с", "1200", "2400", "4800"], 
          correct: 0,
          exp: "ME6 — MELP 600 біт/с." },
        
        { q: "CVSD — це?", 
          opts: ["Аналог", "Дельта-модуляція", "MELP", "Шифрування"], 
          correct: 1,
          exp: "Continuously Variable Slope Delta modulation." },
        
        { q: "120 кбіт/с дає комбо?", 
          opts: ["FIX+MIL-110B", "ALE+SERIAL", "3G+WBHF", "HOP+ARQ"], 
          correct: 2,
          exp: "3G + WBHF = 120 кбіт/с." },
        
        { q: "ME12 — це?", 
          opts: ["12 кбіт/с застарілий", "MELP 1200 біт/с", "Аналог 12 кГц", "Скремблер"], 
          correct: 1,
          exp: "ME12 — MELP 1200 біт/с." },
        
        // 36-40 технічні
        { q: "Діапазон RF-7800H-MP?", 
          opts: ["1,5-30 МГц", "30-300", "1,5-59,9999", "300-3000"], 
          correct: 2,
          exp: "1,5 – 59,9999 МГц." },
        
        { q: "MPR-9600-MP діапазон?", 
          opts: ["1,6-29,9999", "1,5-59,9999", "30-512", "1,5-30"], 
          correct: 0,
          exp: "1,6-29,9999 МГц." },
        
        { q: "HIGH потужність у КХ?", 
          opts: ["5 Вт", "10", "20", "50"], 
          correct: 2,
          exp: "HIGH = 20 Вт." },
        
        { q: "MEDIUM потужність?", 
          opts: ["1 Вт", "5", "10", "20"], 
          correct: 1,
          exp: "MEDIUM = 5 Вт." },
        
        { q: "Номінальна напруга?", 
          opts: ["12 В", "24", "26", "32"], 
          correct: 2,
          exp: "26 В (21,5-32 В)." },
        
        // 41-45
        { q: "LQA — це?", 
          opts: ["Пошук координат", "Аналіз якості каналу", "Тест потужності", "Перевірка антени"], 
          correct: 1,
          exp: "Link Quality Analysis." },
        
        { q: "EXCHANGE та SOUND — це?", 
          opts: ["Синхронізація", "LQA-тести", "Модуляції", "Вокодери"], 
          correct: 1,
          exp: "Види LQA-тесту." },
        
        { q: "LDV — це?", 
          opts: ["Голосове повідомлення в 3G", "Режим частоти", "Модем", "Ключ"], 
          correct: 0,
          exp: "Low Data Rate Digital Voice." },
        
        { q: "Макс. тривалість LDV?", 
          opts: ["30 с", "1 хв 50 с", "5 хв", "10 хв"], 
          correct: 1,
          exp: "1 хвилина 50 секунд." },
        
        { q: "Citadel-128 ключ?", 
          opts: ["16 символів", "32", "64", "128"], 
          correct: 1,
          exp: "128 біт = 32 символи." },
        
        // 46-50
        { q: "AES-256 ключ?", 
          opts: ["32", "64", "128", "256"], 
          correct: 1,
          exp: "256 біт = 64 символи." },
        
        { q: "ME600 — це?", 
          opts: ["600 біт/с", "1200", "2400", "4800"], 
          correct: 0,
          exp: "MELP 600 біт/с." },
        
        { q: "CT на перемикачі?", 
          opts: ["Вимк.", "Відкритий", "Засекречений", "Обнулення"], 
          correct: 2,
          exp: "Cipher Text — зашифрований режим." },
        
        { q: "Кнопка CALL для?", 
          opts: ["Яскравості", "Шумоподавлення", "Виклику/синхронізації", "Програмування"], 
          correct: 2,
          exp: "Ініціювання виклику ALE/3G/HOP." },
        
        { q: "Що таке ППРЧ?", 
          opts: ["Постійна частота", "Псевдовипадкова перестройка частоти", "Потужний передавач", "Прийом сигналу"], 
          correct: 1,
          exp: "Те саме, що HOP — Frequency Hopping." }
    ];

    const container = document.getElementById('questionsContainer');
    const scoreSpan = document.getElementById('scoreDisplay');

    function render() {
        let html = '';
        questions.forEach((q, i) => {
            html += `
                <div class="card" id="card-${i}">
                    <div class="qtitle">
                        <span class="qnum">${i+1}</span>
                        ${q.q}
                    </div>
                    <div class="options">
                        ${q.opts.map((opt, oi) => `
                            <label class="opt">
                                <input type="radio" name="q${i}" value="${oi}">
                                <span>${opt}</span>
                            </label>
                        `).join('')}
                    </div>
                    <div class="feedback" id="fb-${i}" style="display:none"></div>
                </div>
            `;
        });
        container.innerHTML = html;
    }

    function checkAll() {
        let correct = 0;
        for (let i = 0; i < questions.length; i++) {
            const radios = document.getElementsByName(`q${i}`);
            let selected = null;
            for (let j = 0; j < radios.length; j++) {
                if (radios[j].checked) {
                    selected = parseInt(radios[j].value);
                    break;
                }
            }
            
            const card = document.getElementById(`card-${i}`);
            const fb = document.getElementById(`fb-${i}`);
            
            if (selected === null) {
                card.classList.add('incorrect');
                card.classList.remove('correct');
                fb.innerHTML = '<span class="wrong-msg">❌ Не обрано</span><div class="explain">' + questions[i].exp + '</div>';
                fb.style.display = 'block';
            } else if (selected === questions[i].correct) {
                card.classList.add('correct');
                card.classList.remove('incorrect');
                fb.innerHTML = '<span class="correct-msg">✅ Правильно</span><div class="explain">' + questions[i].exp + '</div>';
                fb.style.display = 'block';
                correct++;
            } else {
                card.classList.add('incorrect');
                card.classList.remove('correct');
                fb.innerHTML = '<span class="wrong-msg">❌ Помилка</span><div class="explain">' + questions[i].exp + '</div>';
                fb.style.display = 'block';
            }
        }
        scoreSpan.innerText = `${correct}/${questions.length}`;
    }

    function reset() {
        for (let i = 0; i < questions.length; i++) {
            const radios = document.getElementsByName(`q${i}`);
            for (let j = 0; j < radios.length; j++) {
                radios[j].checked = false;
            }
            const card = document.getElementById(`card-${i}`);
            const fb = document.getElementById(`fb-${i}`);
            card.classList.remove('correct', 'incorrect');
            fb.style.display = 'none';
        }
        scoreSpan.innerText = `0/${questions.length}`;
    }

    function updateScore() {
        let correct = 0;
        for (let i = 0; i < questions.length; i++) {
            const radios = document.getElementsByName(`q${i}`);
            for (let j = 0; j < radios.length; j++) {
                if (radios[j].checked && parseInt(radios[j].value) === questions[i].correct) {
                    correct++;
                    break;
                }
            }
        }
        scoreSpan.innerText = `${correct}/${questions.length}`;
    }

    render();
    
    for (let i = 0; i < questions.length; i++) {
        const radios = document.getElementsByName(`q${i}`);
        for (let j = 0; j < radios.length; j++) {
            radios[j].addEventListener('change', updateScore);
        }
    }

    document.getElementById('checkBtn').addEventListener('click', checkAll);
    document.getElementById('resetBtn').addEventListener('click', reset);
})();
</script>
</body>
</html>
